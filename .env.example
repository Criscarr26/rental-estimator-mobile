# Copy to .env and fill with your Supabase project values
# (Dashboard > Project Settings > API). Restart `npx expo start` after editing.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Tasador SD API base URL. When set, the app syncs its model weights from
# GET /v1/model/params on launch (bundled weights stay as offline fallback),
# so a retrained+redeployed model reaches the app with no new build.
EXPO_PUBLIC_MODEL_API_URL=https://tasador-sd.vercel.app
